@article{Wang_2025,
    doi = {10.1088/0256-307X/42/11/110712},
    url = {https://doi.org/10.1088/0256-307X/42/11/110712},
    year = {2025},
    month = {nov},
    publisher = {Chinese Physical Society and IOP Publishing Ltd},
    volume = {42},
    number = {11},
    pages = {110712},
    author = {Wang, Zhe and Deng, Zehui and Liu, Zenan and Wang, Zhiyan and Ding, Yi-Ming and Zhang, Long and Guo, Wenan and Yan, Zheng},
    title = {Universal Behavior in Entanglement Entropy Reveals Quantum Criticality and Underlying Symmetry Breaking},
    journal = {Chinese Physics Letters},
    abstract = {Entanglement plays a key role in quantum physics, but how much information it can extract from many-body systems is still an open question, particularly regarding quantum criticalities and emergent symmetries. In this work, we systematically study the entanglement entropy (EE) and derivative entanglement entropy (DEE) near quantum phase transitions in various quantum many-body systems. A one-parameter scaling relation between the DEE and system size at the critical point has been derived for the first time, which successfully obtains the critical exponent via data collapse. Furthermore, we find that the EE peaks at the (emergent) symmetry-enhanced first-order transition, reflecting higher symmetry breaking. This work provides a new paradigm for quantum many-body research from the perspective of EE and DEE.}
}

